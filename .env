## ============================================================================
## CKP Evidence App - Production Environment (Vercel) Configuration
## ============================================================================

# ============================================================================
# PORT Configuration
# ============================================================================
PORT=3000
NODE_ENV=production

# ============================================================================
# Google Cloud Service Account Configuration
# ============================================================================
# Use JSON service account content directly (for Vercel)
# Set via: npm run vercel:env:google
GOOGLE_SERVICE_ACCOUNT_JSON=

# ============================================================================
# Vercel Blob Storage Configuration - CRITICAL FOR PRODUCTION
# ============================================================================
# Get this token from Vercel Dashboard > Storage > Blob
# Token enables persistent storage of:
# - Data (app-data.json)
# - Manual uploaded evidence files
# - Generated PDF outputs
# Set via: Vercel Dashboard > Project Settings > Environment Variables
BLOB_READ_WRITE_TOKEN=

# Path untuk menyimpan data JSON di Vercel Blob
DATA_BLOB_PATH=data/app-data.json

# ============================================================================
# File Storage Paths
# ============================================================================
# For Vercel: these should NOT be used (use Blob instead)
# For local development: configure as needed
TMP_DIR=storage/tmp
OUTPUT_DIR=storage/output
EVIDENCE_DIR=storage/evidence

# ============================================================================
# Upload Configuration
# ============================================================================
# Maximum file upload size per file (MB)
# Vercel limit: 4.5 MB per function execution
# Recommended: 4 MB
MAX_UPLOAD_MB=4

# ============================================================================
# Logging & Debug
# ============================================================================
# LOG_LEVEL=info
