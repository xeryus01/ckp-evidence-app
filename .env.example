## CKP Evidence App - Environment Variables Template

# ============================================================================
# PORT Configuration
# ============================================================================
PORT=3000

# ============================================================================
# Google Cloud Service Account Configuration
# ============================================================================
# Pilih SALAH SATU dari dua opsi berikut:

# OPSI 1: Gunakan file service-account.json (untuk development lokal)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# OPSI 2: Paste JSON service account langsung dalam 1 baris (untuk production Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","...":...}

# ============================================================================
# Vercel Blob Storage (Cloud File Storage)
# ============================================================================
# Token untuk Vercel Blob - WAJIB untuk production Vercel
# Di Vercel Dashboard, ini akan otomatis di-fill setelah Blob store dihubungkan
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Path di Blob untuk data JSON (opsional, default: data/app-data.json)
# DATA_BLOB_PATH=data/app-data.json

# ============================================================================
# File Storage Paths (Lokal)
# ============================================================================
# Folder untuk temporary processing files
TMP_DIR=storage/tmp

# Folder untuk output PDF yang dihasilkan
OUTPUT_DIR=storage/output

# Folder untuk manual uploaded evidence files
EVIDENCE_DIR=storage/evidence

# ============================================================================
# Upload File Size Limit
# ============================================================================
# Maximum file upload size per file (dalam MB)
# Default untuk Vercel: 4 MB (karena serverless function memory limit)
# Default untuk lokal: 50 MB
# MAX_UPLOAD_MB=4

# ============================================================================
# Logging & Debug (Optional)
# ============================================================================
# NODE_ENV=development  # development | production
# LOG_LEVEL=info       # debug | info | warn | error

# ============================================================================
# NOTES:
# ============================================================================
# 1. UNTUK DEVELOPMENT LOKAL:
#    - Gunakan GOOGLE_APPLICATION_CREDENTIALS dengan file path
#    - Kosongkan BLOB_READ_WRITE_TOKEN (data disimpan lokal)
#    - Buat file .env dari file ini: cp .env.example .env
#
# 2. UNTUK PRODUCTION VERCEL:
#    - Gunakan GOOGLE_SERVICE_ACCOUNT_JSON dengan JSON content
#    - Set BLOB_READ_WRITE_TOKEN dari Vercel Blob Storage
#    - Tambahkan env variables via: npm run vercel:env:google
#
# 3. Jangan commit .env atau service-account.json ke git
#    (sudah di .gitignore)
