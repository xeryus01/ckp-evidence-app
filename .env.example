PORT=3000
# Pilih salah satu:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# atau isi JSON service account langsung dalam 1 baris:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Vercel Blob otomatis mengisi token ini setelah Blob store dihubungkan.
# Untuk deploy Vercel, token ini wajib agar data, upload, dan PDF tersimpan permanen.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
DATA_BLOB_PATH=data/app-data.json

# Folder output dan tmp lokal. Di Vercel, tmp otomatis memakai /tmp/ckp-evidence.
TMP_DIR=storage/tmp
OUTPUT_DIR=storage/output
EVIDENCE_DIR=storage/evidence

# Batas file per upload. Default lokal 50 MB, default Vercel 4 MB.
# MAX_UPLOAD_MB=4
